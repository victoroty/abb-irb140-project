<?xml version="1.0" ?>

<robot name="abb_irb140" xmlns:xacro="http://ros.org/wiki/xacro">
        <xacro:arg name="use_gazebo" default="false"/>
	<xacro:include filename="$(find abb_irb140_support)/urdf/irb140_macro.xacro"/>
	<xacro:abb_irb140 prefix=""/>
<ros2_control name="IRB140System" type="system">
  <hardware>
    <xacro:if value="$(arg use_gazebo)">
      <plugin>gz_ros2_control/GazeboSimSystem</plugin>
      <param name="position_proportional_gain">0.8</param>
    </xacro:if>

    <xacro:unless value="$(arg use_gazebo)">
      <plugin>mock_components/GenericSystem</plugin>
    </xacro:unless>
  </hardware>

  <joint name="joint_1">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="joint_2">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="joint_3">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="joint_4">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="joint_5">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="joint_6">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <joint name="gripper_finger_joint1">
    <command_interface name="position"/>
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

  <!--
    State-only mimic finger for Gazebo.

    gripper_finger_joint1 is the commanded joint.
    gripper_finger_joint2 already has a URDF <mimic> tag in the gripper macro.
    For gz_ros2_control, the mimic joint must not have a command interface.
  -->
  <joint name="gripper_finger_joint2">
    <state_interface name="position"/>
    <state_interface name="velocity"/>
  </joint>

</ros2_control>

<xacro:if value="$(arg use_gazebo)">
  <!--
    Massless world root used in Gazebo mode.

    This prevents KDL from treating base_link, which has inertia, as the
    root link of the robot tree.
  -->
  <link name="world"/>

  <joint name="world_to_base_link" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <gazebo>
    <plugin
      filename="libgz_ros2_control-system.so"
      name="gz_ros2_control::GazeboSimROS2ControlPlugin">
      <parameters>$(find abb_irb140_moveit_config)/config/ros2_controllers.yaml</parameters>
    </plugin>
  </gazebo>
</xacro:if>

</robot>
