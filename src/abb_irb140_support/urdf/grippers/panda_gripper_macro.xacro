<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="panda_gripper" params="parent prefix">

    <!-- Mount ABB tool0 to gripper body -->
    <joint name="${prefix}mount_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}panda_hand"/>
      <origin xyz="0.0025 0 0" rpy="0 -1.5708 3.14159"/>
    </joint>

    <!-- Gripper body -->
    <link name="${prefix}panda_hand">
      <visual>
        <geometry>
          <mesh filename="file:///opt/ros/jazzy/share/moveit_resources_panda_description/meshes/visual/hand.dae"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <mesh filename="file:///opt/ros/jazzy/share/moveit_resources_panda_description/meshes/collision/hand.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- Left finger -->
    <link name="${prefix}leftfinger">
      <visual>
        <geometry>
          <mesh filename="file:///opt/ros/jazzy/share/moveit_resources_panda_description/meshes/visual/finger.dae"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <mesh filename="file:///opt/ros/jazzy/share/moveit_resources_panda_description/meshes/collision/finger.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- Right finger -->
    <link name="${prefix}rightfinger">
      <visual>
        <geometry>
          <mesh filename="file:///opt/ros/jazzy/share/moveit_resources_panda_description/meshes/visual/finger.dae"/>
        </geometry>
      </visual>

      <collision>
        <geometry>
          <mesh filename="file:///opt/ros/jazzy/share/moveit_resources_panda_description/meshes/collision/finger.stl"/>
        </geometry>
      </collision>
    </link>

    <!-- Left finger joint -->
    <joint name="${prefix}finger_joint1" type="prismatic">
      <parent link="${prefix}panda_hand"/>
      <child link="${prefix}leftfinger"/>
      <origin xyz="0 0 0.0584" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.04" effort="100" velocity="0.2"/>
    </joint>

    <!-- Right finger joint -->
    <joint name="${prefix}finger_joint2" type="prismatic">
      <parent link="${prefix}panda_hand"/>
      <child link="${prefix}rightfinger"/>
      <origin xyz="0 0 0.0584" rpy="0 0 3.14159"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.04" effort="100" velocity="0.2"/>
      <mimic joint="${prefix}finger_joint1"/>
    </joint>

  </xacro:macro>

</robot>
